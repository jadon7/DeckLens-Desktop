{
  "name": "decklens-desktop",
  "version": "0.2.3",
  "private": true,
  "description": "DeckLens desktop shell for macOS and Windows.",
  "author": "DeckLens",
  "main": "electron/main.cjs",
  "scripts": {
    "electron:dev": "electron .",
    "electron:pack": "electron-builder --dir",
    "electron:pack:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir --config.mac.sign=null --config.mac.notarize=false",
    "electron:dist": "electron-builder",
    "electron:dist:mac": "electron-builder --mac",
    "electron:dist:mac:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac zip --config.mac.identity=null --config.mac.sign=null --config.mac.notarize=false",
    "electron:dist:mac:signed": "APPLE_KEYCHAIN_PROFILE=decklens-notary electron-builder --mac",
    "electron:dist:win": "electron-builder --win",
    "electron:dist:win:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis --x64",
    "decklens:convert": "python3 decklens_cli.py",
    "site:deploy": "wrangler pages deploy site --project-name decklens-site --branch main"
  },
  "devDependencies": {
    "electron": "42.0.1",
    "electron-builder": "26.8.1",
    "wrangler": "^4.90.1"
  },
  "build": {
    "appId": "app.decklens.desktop",
    "productName": "DeckLens",
    "asar": true,
    "compression": "normal",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://updates.dsxzai.com/"
      }
    ],
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "app.py",
        "to": "backend/app.py"
      },
      {
        "from": "engine.py",
        "to": "backend/engine.py"
      },
      {
        "from": "decklens_cli.py",
        "to": "backend/decklens_cli.py"
      },
      {
        "from": "requirements.txt",
        "to": "backend/requirements.txt"
      },
      {
        "from": "templates",
        "to": "backend/templates",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "static",
        "to": "backend/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "font_matcher",
        "to": "backend/font_matcher",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      }
    ],
    "mac": {
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true,
      "sign": "./build/sign-mac.cjs",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
