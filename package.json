{
  "name": "decklens-desktop",
  "version": "0.2.11",
  "private": true,
  "description": "DeckLens desktop shell for macOS and Windows.",
  "author": "DeckLens",
  "main": "electron/main.cjs",
  "bin": {
    "decklens": "bin/decklens.cjs"
  },
  "scripts": {
    "electron:dev": "electron .",
    "electron:pack": "electron-builder --dir",
    "electron:pack:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir --config.mac.identity=null --config.mac.notarize=false",
    "electron:dist": "electron-builder",
    "electron:dist:mac": "electron-builder --mac",
    "electron:dist:mac:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac zip --config.mac.identity=null --config.mac.notarize=false",
    "electron:dist:mac:signed": "APPLE_KEYCHAIN_PROFILE=decklens-notary electron-builder --mac",
    "electron:dist:win": "electron-builder --win",
    "electron:dist:win:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis --x64",
    "decklens": "node bin/decklens.cjs",
    "decklens:convert": "node bin/decklens.cjs convert",
    "site:deploy": "wrangler pages deploy site --project-name decklens-site --branch main"
  },
  "devDependencies": {
    "electron": "42.0.1",
    "electron-builder": "26.8.1",
    "wrangler": "^4.90.1"
  },
  "build": {
    "appId": "app.decklens.desktop",
    "productName": "DeckLens",
    "asar": true,
    "compression": "normal",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://updates.dsxzai.com/"
      }
    ],
    "files": [
      "electron/**/*",
      "lib/**/*"
    ],
    "extraResources": [
      {
        "from": "app.py",
        "to": "backend/app.py"
      },
      {
        "from": "engine.py",
        "to": "backend/engine.py"
      },
      {
        "from": "decklens_cli.py",
        "to": "backend/decklens_cli.py"
      },
      {
        "from": "bin",
        "to": "cli",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "lib/agent-skills.cjs",
        "to": "cli/agent-skills.cjs"
      },
      {
        "from": "node_modules/@img",
        "to": "cli/node_modules/@img"
      },
      {
        "from": "node_modules/core-util-is",
        "to": "cli/node_modules/core-util-is"
      },
      {
        "from": "node_modules/detect-libc",
        "to": "cli/node_modules/detect-libc"
      },
      {
        "from": "node_modules/immediate",
        "to": "cli/node_modules/immediate"
      },
      {
        "from": "node_modules/inherits",
        "to": "cli/node_modules/inherits"
      },
      {
        "from": "node_modules/isarray",
        "to": "cli/node_modules/isarray"
      },
      {
        "from": "node_modules/jszip",
        "to": "cli/node_modules/jszip"
      },
      {
        "from": "node_modules/lie",
        "to": "cli/node_modules/lie"
      },
      {
        "from": "node_modules/pako",
        "to": "cli/node_modules/pako"
      },
      {
        "from": "node_modules/process-nextick-args",
        "to": "cli/node_modules/process-nextick-args"
      },
      {
        "from": "node_modules/readable-stream",
        "to": "cli/node_modules/readable-stream"
      },
      {
        "from": "node_modules/safe-buffer",
        "to": "cli/node_modules/safe-buffer"
      },
      {
        "from": "node_modules/semver",
        "to": "cli/node_modules/semver"
      },
      {
        "from": "node_modules/setimmediate",
        "to": "cli/node_modules/setimmediate"
      },
      {
        "from": "node_modules/sharp",
        "to": "cli/node_modules/sharp"
      },
      {
        "from": "node_modules/string_decoder",
        "to": "cli/node_modules/string_decoder"
      },
      {
        "from": "node_modules/util-deprecate",
        "to": "cli/node_modules/util-deprecate"
      },
      {
        "from": "node_modules/lucide-static/icons",
        "to": "cli/icons/lucide-static"
      },
      {
        "from": "node_modules/@tabler/icons/icons",
        "to": "cli/icons/tabler-icons"
      },
      {
        "from": "node_modules/heroicons",
        "to": "cli/icons/heroicons"
      },
      {
        "from": "node_modules/phosphor-icons/src",
        "to": "cli/icons/phosphor-icons"
      },
      {
        "from": "skills",
        "to": "skills",
        "filter": [
          "decklens-convert/**"
        ]
      },
      {
        "from": "requirements.txt",
        "to": "backend/requirements.txt"
      },
      {
        "from": "templates",
        "to": "backend/templates",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "static",
        "to": "backend/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "font_matcher",
        "to": "backend/font_matcher",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      }
    ],
    "mac": {
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true,
      "sign": "./build/sign-mac.cjs",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@tabler/icons": "^3.44.0",
    "electron-updater": "^6.8.3",
    "heroicons": "^2.2.0",
    "jszip": "^3.10.1",
    "lucide-static": "^1.16.0",
    "phosphor-icons": "^1.4.2",
    "sharp": "^0.34.5"
  }
}
